{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["pnpm-lock.yaml"],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["^build"]
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"],
			"inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.turbo/**", "!**/dist/**"]
		},
		"lint": {
			"cache": false
		},
		"test": {
			"outputs": []
		}
	}
}
